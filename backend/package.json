{
  "name": "sands-ornaments-backend",
  "version": "1.0.0",
  "description": "Sands Ornaments - Node.js + Express + MongoDB Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:admin": "node src/seeders/adminSeeder.js",
    "seed:categories": "node src/seeders/categorySeeder.js",
    "seed:products": "node src/seeders/productSeeder.js",
    "test:ops-smoke": "node scripts/ops-smoke-tests.js",
    "test:ops-transitions": "node scripts/ops-transition-tests.js",
    "test:ops-integrity": "node scripts/ops-integrity-tests.js",
    "test:ops-e2e": "node scripts/ops-e2e-tests.js",
    "test:ops-errors": "node scripts/ops-error-tests.js",
    "test:user-ui-api-smoke": "node scripts/user-ui-api-smoke.js",
    "migrate:product-variant-pricing:dry": "node scripts/migrate-product-variant-pricing.js",
    "migrate:product-variant-pricing": "node scripts/migrate-product-variant-pricing.js --apply",
    "migrate:product-pricing-formula:dry": "node scripts/migrate-product-pricing-formula.js",
    "migrate:product-pricing-formula": "node scripts/migrate-product-pricing-formula.js --apply",
    "migrate:product-purity:dry": "node scripts/migrate-product-purity.js",
    "migrate:product-purity": "node scripts/migrate-product-purity.js --apply",
    "backup:categories": "node scripts/backup-categories.js",
    "migrate:remove-category-metal:dry": "node scripts/migrate-remove-category-metal.js",
    "migrate:remove-category-metal": "node scripts/migrate-remove-category-metal.js --apply",
    "migrate:review-unique-index:dry": "node scripts/migrate-review-unique-index.js",
    "migrate:review-unique-index": "node scripts/migrate-review-unique-index.js --apply"
  },
  "dependencies": {
    "@fluidjs/multer-cloudinary": "^1.0.4",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.9.0",
    "helmet": "^7.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "razorpay": "^2.9.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
